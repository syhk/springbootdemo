#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*) basedir=`cygpath -w "$basedir"`;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../_esbuild@0.15.9@esbuild/bin/esbuild" "$@"
else 
  exec node  "$basedir/../_esbuild@0.15.9@esbuild/bin/esbuild" "$@"
fi
